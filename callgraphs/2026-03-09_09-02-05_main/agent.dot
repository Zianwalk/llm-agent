digraph "agent" {
  graph [rankdir=TB, bgcolor="#0d1117", pad=0.8, ranksep=1.2, nodesep=0.8, fontname="Courier New"];
  node  [shape=box, style="filled,rounded", fillcolor="white", fontcolor="#111111",
         fontname="Courier New", fontsize=12, color="#888888", width=1.6, penwidth=1.5];
  edge  [arrowsize=0.8, penwidth=2.0];
  { rank=same; agent; build_tool_prompt }
  { rank=same; calculator; llm; parse_tool_call }
  { rank=same; load_model }
  agent [label="agent"];
  build_tool_prompt [label="build_tool_prompt"];
  calculator [label="calculator"];
  llm [label="llm"];
  load_model [label="load_model"];
  parse_tool_call [label="parse_tool_call"];
  agent -> calculator [color="#00cfff", penwidth=2.0];
  agent -> llm [color="#00cfff", penwidth=2.0];
  agent -> parse_tool_call [color="#00cfff", penwidth=2.0];
  llm -> load_model [color="#ffaa00", style=dashed, penwidth=2.0, label="   globals   ", fontcolor="white", fontsize=11, labeldistance=5.0, labelangle=45];
}