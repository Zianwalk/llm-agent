digraph "agent" {
  graph [rankdir=TB, bgcolor="#0d1117", pad=0.8, ranksep=1.2, nodesep=0.8, fontname="Courier New"];
  node  [shape=box, style="filled,rounded", fillcolor="white", fontcolor="#111111",
         fontname="Courier New", fontsize=12, color="#888888", width=1.6, penwidth=1.5];
  edge  [arrowsize=0.8, penwidth=2.0];
  { rank=same; calculator; load_model }
  { rank=same; build_tool_prompt; llm; parse_tool_call }
  { rank=same; agent }
  agent [label="agent"];
  build_tool_prompt [label="build_tool_prompt"];
  calculator [label="calculator"];
  llm [label="llm"];
  load_model [label="load_model"];
  parse_tool_call [label="parse_tool_call"];
  build_tool_prompt -> agent [color="#00cfff", penwidth=2.0];
  calculator -> agent [color="#00cfff", penwidth=2.0];
  calculator -> build_tool_prompt [color="#00cfff", penwidth=2.0];
  calculator -> parse_tool_call [color="#00cfff", penwidth=2.0];
  llm -> agent [color="#00cfff", penwidth=2.0];
  load_model -> llm [color="#00cfff", penwidth=2.0];
  parse_tool_call -> agent [color="#00cfff", penwidth=2.0];
}