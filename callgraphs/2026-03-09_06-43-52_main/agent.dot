digraph "agent" {
  graph [rankdir=TB, bgcolor="#0d1117", pad=0.8, ranksep=1.0, nodesep=0.7, fontname="Courier New"];
  node  [shape=box, style="filled,rounded", fillcolor="#161b22", fontcolor="#c9d1d9",
         fontname="Courier New", fontsize=12, color="#30363d", width=1.6];
  edge  [arrowsize=0.7, penwidth=1.3];
  { rank=same; agent; build_tool_prompt }
  { rank=same; calculator; llm; parse_tool_call }
  { rank=same; load_model }
  agent [label="agent"];
  build_tool_prompt [label="build_tool_prompt"];
  calculator [label="calculator"];
  llm [label="llm"];
  load_model [label="load_model"];
  parse_tool_call [label="parse_tool_call"];
  agent -> calculator [color="#58a6ff"];
  agent -> llm [color="#58a6ff"];
  agent -> parse_tool_call [color="#58a6ff"];
  llm -> load_model [color="#f0883e", style=dashed, label="uses globals"];
}