digraph G {
  graph [rankdir=LR, bgcolor="#0d1117", pad=0.6, splines=curved, fontname="Courier New"];
  node  [shape=box, style="filled,rounded", fillcolor="#161b22", fontcolor="#c9d1d9",
         fontname="Courier New", fontsize=11, color="#30363d"];
  edge  [color="#58a6ff", arrowsize=0.7, penwidth=1.2];

    graph [rankdir=TB];
    subgraph cluster_G {

        graph [style="filled,rounded", fillcolor="#80808018", label=""];
        agent [label="agent", style="filled", fillcolor="#ffffffb2", fontcolor="#000000", group="0"];
        llm_call [label="llm_call", style="filled", fillcolor="#ffffffb2", fontcolor="#000000", group="1"];
        agent__agent [label="agent", style="filled", fillcolor="#ffffffb2", fontcolor="#000000", group="0"];
        agent__build_tool_prompt [label="build_tool_prompt", style="filled", fillcolor="#ffffffb2", fontcolor="#000000", group="0"];
        agent__calculator [label="calculator", style="filled", fillcolor="#ffffffb2", fontcolor="#000000", group="0"];
        agent__llm [label="llm", style="filled", fillcolor="#ffffffb2", fontcolor="#000000", group="0"];
        agent__load_model [label="load_model", style="filled", fillcolor="#ffffffb2", fontcolor="#000000", group="0"];
        agent__parse_tool_call [label="parse_tool_call", style="filled", fillcolor="#ffffffb2", fontcolor="#000000", group="0"];
        llm_call__llm [label="llm", style="filled", fillcolor="#ffffffb2", fontcolor="#000000", group="1"];
        llm_call__load_model [label="load_model", style="filled", fillcolor="#ffffffb2", fontcolor="#000000", group="1"];
    }
        agent -> agent__agent [style="solid",  color="#000000"];
        agent -> agent__calculator [style="solid",  color="#000000"];
        agent -> agent__build_tool_prompt [style="solid",  color="#000000"];
        agent -> agent__load_model [style="solid",  color="#000000"];
        agent__llm -> agent__load_model [style="solid",  color="#000000"];
        agent__agent -> agent__llm [style="solid",  color="#000000"];
        agent__agent -> agent__parse_tool_call [style="solid",  color="#000000"];
        llm_call -> llm_call__llm [style="solid",  color="#000000"];
        llm_call -> llm_call__load_model [style="solid",  color="#000000"];
        llm_call__llm -> llm_call__load_model [style="solid",  color="#000000"];
    }
